@page "/"
@page "/login"
@layout PublicLayout
@rendermode InteractiveServer

<PageTitle>Sadkah - Login</PageTitle>

<AuthPanel LabelledBy="login-title" ImageUrl="/images/auth/shield-lock.png">
    <div class="login-heading">
        <h1 id="login-title">Welcome <span>Back</span></h1>
        <p>
            Login to continue your journey of
            <strong>making a difference.</strong>
        </p>
    </div>

    <EditForm Model="loginModel" OnValidSubmit="HandleLoginAsync" FormName="login">
        <DataAnnotationsValidator />

        <div class="login-form">
            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="login-alert @statusAlertClass" role="alert">
                    @statusMessage
                </div>
            }

            <AuthFormField TValue="string" Id="email" Label="Email address" For="() => loginModel.Email">
                <InputText id="email"
                           class="auth-input"
                           type="email"
                           autocomplete="email"
                           placeholder="Enter your email"
                           @bind-Value="loginModel.Email" />
            </AuthFormField>

            <AuthFormField TValue="string" Id="password" Label="Password" For="() => loginModel.Password">
                <InputText id="password"
                           class="auth-input"
                           type="password"
                           autocomplete="current-password"
                           placeholder="Enter your password"
                           @bind-Value="loginModel.Password" />
            </AuthFormField>

            <div class="login-options">
                <label class="remember-option">
                    <input type="checkbox" />
                    <span>Remember me</span>
                </label>
                <a href="/forgot-password">Forgot password?</a>
            </div>

            <AppButton Type="submit"
                       Size="md"
                       FullWidth="true"
                       IsLoading="@isSubmitting"
                       LoadingText="Logging in...">
                Log in
            </AppButton>

            <p class="signup-copy">
                Don't have an account?
                <a href="/signup">Sign up</a>
            </p>
        </div>
    </EditForm>
</AuthPanel>
