@page "/campaigns"
@layout AppLayout
@rendermode InteractiveServer

<PageTitle>Sadkah - Campaigns</PageTitle>

<div class="header-content">
    <div class="header-text">
        <h1>Find verified causes</h1>
        <p>Search, filter, and donate to campaigns that matter to you</p>
    </div>
    <div class="header-filters">
        <AppSearchInput Id="search-campaigns"
                        Placeholder="Search campaigns..."
                        Debounce="300"
                        ValueChanged="SearchCampaignsAsync">
            <LeftIcon>
                <SearchIcon />
            </LeftIcon>
        </AppSearchInput>
        <AppButton Class="filter-button" Variant="secondary"
                   Size="md"
                   aria-expanded="@showFilters"
                   @onclick="ToggleFilters">
            <FilterIcon Width="20" Height="20" />
            <span>
                Filters

                @if (ActiveFilterCount > 0)
                {
                    <span class="filter-count">@ActiveFilterCount</span>
                }
            </span>
        </AppButton>

        <AppButton Class="create-button" Variant="primary" Size="md" @onclick="CreateCampaign">
            <PlusIcon Width="20" Height="20" />
            <span>Create Campaign</span>
        </AppButton>
    </div>
</div>

@if (showFilters)
{
    <section class="filter-panel" aria-label="Campaign filter options">
        <div class="filter-field">
            <label for="campaign-category-filter">Category</label>
            <AppSelectInput TValue="string"
                       Id="campaign-category-filter"
                       Placeholder="All categories"
                       Items="_campaignCategories.Select(c => c.Name)"
                       Value="@selectedCategory"
                       ValueChanged="ChangeCategoryAsync"
                       ValueExpression="@(() => selectedCategory)" />
        </div>

        <div class="filter-field">
            <label for="campaign-location-filter">Location</label>
            <AppSelectInput TValue="string"
                       Id="campaign-location-filter"
                       Placeholder="All locations"
                       Items="AvailableLocations"
                       Value="@selectedLocation"
                       ValueChanged="ChangeLocationAsync"
                       ValueExpression="@(() => selectedLocation)" />
        </div>

        <div class="filter-field">
            <label for="campaign-verification-filter">Verification</label>
            <AppSelectInput TValue="string"
                       Id="campaign-verification-filter"
                       Placeholder="Any status"
                       Value="@verificationFilter"
                       ValueChanged="ChangeVerificationFilterAsync"
                       ValueExpression="@(() => verificationFilter)">
                <option value="@VerifiedFilterValue">Verified only</option>
                <option value="@UnverifiedFilterValue">Unverified only</option>
            </AppSelectInput>
        </div>

        <div class="filter-actions">
            <AppButton Variant="secondary"
                       Size="md"
                       Disabled="@(!HasAdvancedFilters)"
                       @onclick="ClearFilters">
                Clear
            </AppButton>
        </div>
    </section>
}

<div class="filter-tab" role="tablist" aria-label="Campaign filters">
    <AppButton Class="@GetFilterTabClass(CampaignFilter.All)"
               Variant="secondary"
               Size="md"
               aria-pressed="@IsSelected(CampaignFilter.All)"
               @onclick="@(() => SelectFilter(CampaignFilter.All))">
        All
    </AppButton>
    <AppButton Class="@GetFilterTabClass(CampaignFilter.MyCampaigns)"
               Variant="secondary"
               Size="md"
               aria-pressed="@IsSelected(CampaignFilter.MyCampaigns)"
               @onclick="@(() => SelectFilter(CampaignFilter.MyCampaigns))">
        My Campaigns
    </AppButton>
</div>

<section class="campaign-list" aria-label="Campaign list">
    @if (isLoading)
    {
        <p class="campaign-status" role="status">Loading campaigns...</p>
    }
    else if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <p class="campaign-status campaign-status--error" role="alert">@statusMessage</p>
    }
    else if (TotalItems == 0)
    {
        <p class="campaign-status" role="status">No campaigns found.</p>
    }
    else
    {
        @foreach (var campaign in PagedCampaigns)
        {
            <CampaignCard Title="@campaign.Title"
                          Category="@campaign.Category"
                          Location="@campaign.Location"
                          DaysLeft="@campaign.DaysLeft"
                          RaisedAmount="@campaign.RaisedAmount"
                          GoalAmount="@campaign.GoalAmount"
                          IsVerified="@campaign.IsVerified" />
        }

        <PaginationControl CurrentPage="@CurrentPage"
                           TotalPages="@TotalPages"
                           TotalItems="@TotalItems"
                           PageSize="@PageSize"
                           MaxVisiblePages="5"
                           Disabled="@isLoading"
                           ShowSummary="true"
                           AriaLabel="Campaign pagination"
                           Class="campaign-pagination"
                           PageChanged="ChangePage" />
    }
</section>
