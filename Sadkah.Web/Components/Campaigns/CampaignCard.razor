@using System.Globalization

<article class="campaign-card">
    <div class="campaign-card__media">
        <button class="campaign-card__bookmark" type="button" aria-label="Save @Title">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                <path d="M5.83331 4.16667C5.83331 3.70643 6.20641 3.33334 6.66665 3.33334H13.3333C13.7936 3.33334 14.1666 3.70643 14.1666 4.16667V16.6667L9.99998 14.1667L5.83331 16.6667V4.16667Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </button>

        <div class="campaign-card__badges">
            <span class="campaign-card__category">@Category</span>
            @if (IsVerified)
            {
                <span class="campaign-card__verified">
                    <svg width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10 2.5L15.8333 5V9.16667C15.8333 12.925 13.3417 16.4333 10 17.5C6.65833 16.4333 4.16667 12.925 4.16667 9.16667V5L10 2.5Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M7.5 10L9.16667 11.6667L12.9167 7.91667" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    Verified
                </span>
            }
        </div>
    </div>

    <div class="campaign-card__body">
        <h2>@Title</h2>
        <p>@Location &bull; @DaysLeft days left</p>

        <div class="campaign-card__amounts">
            <span>@FormatAmount(RaisedAmount)</span>
            <span>Goal: @FormatAmount(GoalAmount)</span>
        </div>

        <div class="campaign-card__progress" role="progressbar" aria-valuenow="@ProgressPercent" aria-valuemin="0" aria-valuemax="100" aria-label="@Title progress">
            <span style="width: @ProgressPercent%"></span>
        </div>

        <div class="campaign-card__actions">
            <AppButton Variant="secondary" Size="md" FullWidth="true">Details</AppButton>
            <AppButton Variant="primary" Size="md" FullWidth="true">Donate</AppButton>
        </div>
    </div>
</article>

@code {
    private static readonly CultureInfo PesoCulture = new("en-PH");

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Category { get; set; } = string.Empty;

    [Parameter]
    public string Location { get; set; } = string.Empty;

    [Parameter]
    public int DaysLeft { get; set; }

    [Parameter]
    public decimal RaisedAmount { get; set; }

    [Parameter]
    public decimal GoalAmount { get; set; }

    [Parameter]
    public bool IsVerified { get; set; }

    private int ProgressPercent => GoalAmount <= 0
        ? 0
        : Math.Clamp((int)Math.Round(RaisedAmount / GoalAmount * 100), 0, 100);

    private static string FormatAmount(decimal amount)
    {
        return string.Format(PesoCulture, "{0:C0}", amount);
    }
}
