<div class="auth-page">
    @if (isMobile)
    {
        <img src="/images/sadkah-logo.png" alt="Sadkah Logo" class="auth-logo" aria-hidden="true" />
    }
    <section class="auth-panel" aria-labelledby="@LabelledBy">
        @if (!isMobile)
        {
            <img src="/images/sadkah-logo.png" alt="Sadkah Logo" class="auth-logo" aria-hidden="true" />
        }
        <div class="auth-content">
            @ChildContent
        </div>
    </section>
    <div class="auth-illustration">
        <img src="@ImageUrl" alt="Authentication Illustration" />
    </div>
</div>

@code {
    [Parameter]
    public string? LabelledBy { get; set; }

    [Parameter]
    public string? ImageUrl { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Inject]
    private IJSRuntime JsRuntime { get; set; } = default!;

    private bool isMobile;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        isMobile = await ScreenSizeUtility.IsMobileAsync(JsRuntime);
        StateHasChanged();
    }
}
