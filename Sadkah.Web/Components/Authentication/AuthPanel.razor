<div class="auth-page">
    <img src="/images/sadkah-logo.png" alt="Sadkah Logo" class="auth-logo auth-logo-mobile" aria-hidden="true" />

    <section class="auth-panel" aria-labelledby="@LabelledBy">
        <img src="/images/sadkah-logo.png" alt="Sadkah Logo" class="auth-logo auth-logo-desktop" aria-hidden="true" />

        <div class="auth-content">
            @ChildContent
        </div>
    </section>
    <div class="auth-illustration">
        <img src="@ImageUrl" alt="Authentication Illustration" />
    </div>
</div>

@code {
    [Parameter]
    public string? LabelledBy { get; set; }

    [Parameter]
    public string? ImageUrl { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
