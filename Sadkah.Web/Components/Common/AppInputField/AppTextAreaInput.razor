@inherits InputTextArea

<AppInputWrapper Class="@CssClass" LeftIcon="@LeftIcon" WrapperCssClass="@WrapperCssClass">
    <textarea @attributes="AdditionalAttributes"
              id="@Id"
              class="app-input__control"
              placeholder="@Placeholder"
              @bind="CurrentValueAsString"
              @bind:event="onchange">
    </textarea>
</AppInputWrapper>

@code {
    [Parameter]
    public string? Id { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public RenderFragment? LeftIcon { get; set; }

    [Parameter]
    public string WrapperCssClass { get; set; } = string.Empty;
}