<div class="@ComputedClass">
    @if (LeftIcon is not null)
    {
        <span class="app-input__icon" aria-hidden="true">
            @LeftIcon
        </span>
    }
    @ChildContent
    @RightContent
</div>

@code {
    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? LeftIcon { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public RenderFragment? RightContent { get; set; }

    [Parameter]
    public bool HasRightIcon { get; set; }

    [Parameter]
    public string WrapperCssClass { get; set; } = string.Empty;

    [CascadingParameter(Name = "IsInvalid")]
    public bool IsInvalid { get; set; }

    private string ComputedClass
    {
        get
        {
            var classes = new List<string> { "app-input" };

            if (!string.IsNullOrWhiteSpace(Class))
                classes.Add(Class);

            if (LeftIcon is not null)
                classes.Add("app-input--with-left-icon");

            if (HasRightIcon)
                classes.Add("app-input--with-right-icon");

            if (IsInvalid)
                classes.Add("invalid");

            if (!string.IsNullOrWhiteSpace(WrapperCssClass))
                classes.Add(WrapperCssClass);

            return string.Join(" ", classes);
        }
    }
}
